## Backend environment variables for AI Healthcare Assistant

# PostgreSQL connection string (Neon or other Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret key (use a long random string in real envs)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI API key (for intake chat + summaries)
OPENAI_API_KEY=sk-your-openai-key-here

# Email (Resend)
RESEND_API_KEY=re_your_resend_key_here
FROM_EMAIL=noreply@example.com

# N8N webhook URLs (optional for demo)
N8N_WEBHOOK_BOOKING=https://your-n8n-instance.com/webhook/booking
N8N_WEBHOOK_INTAKE_COMPLETE=https://your-n8n-instance.com/webhook/intake-complete
N8N_WEBHOOK_PRESCRIPTION=https://your-n8n-instance.com/webhook/prescription

# Frontend/Backend URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

