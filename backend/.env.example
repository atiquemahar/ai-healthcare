# Database - get from neon.tech
DATABASE_URL=postgresql://user:password@host/dbname

# Auth - generate any random 32+ char string
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# Email - get from resend.com
RESEND_API_KEY=re_
FROM_EMAIL=noreply@yourdomain.com

# N8N - your N8N webhook URLs
N8N_WEBHOOK_BOOKING=https://your-n8n-instance.com/webhook/booking

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
